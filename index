<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>進化光芒特效測試 - v9.3</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 進化前的白光震動 */
        @keyframes evo-white-pulse {
            0% { filter: brightness(1) contrast(1); transform: scale(1); }
            20% { filter: brightness(20) contrast(0); transform: scale(1.05); }
            40% { filter: brightness(1) contrast(1); transform: scale(1); }
            60% { filter: brightness(20) contrast(0); transform: scale(1.1); }
            100% { filter: brightness(1) contrast(1); transform: scale(1); }
        }
        
        /* 最終炸開的光芒動畫 */
        @keyframes blast {
            0% { transform: scale(0); opacity: 1; }
            100% { transform: scale(3); opacity: 0; }
        }

        .evo-anim { animation: evo-white-pulse 0.5s infinite; }
        
        #evo-overlay { 
            position: fixed; inset: 0; 
            background: white; z-index: 1000; 
            display: none; align-items: center; justify-content: center; 
            flex-direction: column;
            transition: background 0.5s;
        }

        .blast-ring {
            position: absolute; width: 200px; height: 200px;
            border: 10px solid gold; border-radius: 50%;
            display: none; animation: blast 0.6s ease-out;
        }
    </style>
</head>
<body class="bg-slate-950 text-white flex flex-col items-center justify-center min-h-screen">

    <div class="text-center">
        <h1 class="text-2xl font-bold mb-8 text-slate-400">進化系統測試沙盒</h1>
        <div class="bg-slate-900 p-10 rounded-[3rem] border-2 border-slate-800 shadow-2xl">
            <div id="preview-img" class="w-48 h-48 bg-contain bg-no-repeat bg-center mb-6" 
                 style="background-image:url('https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/4.png')"></div>
            <p class="text-xl font-bold text-orange-400 mb-6">小火龍 (EXP: 50/50)</p>
            <button onclick="startEvolution()" class="bg-yellow-500 text-black px-10 py-4 rounded-full font-black text-xl hover:scale-105 active:scale-95 transition">
                觸發進化！
            </button>
        </div>
    </div>

    <div id="evo-overlay">
        <div id="blast-circle" class="blast-ring"></div>
        <div id="evo-img-flash" class="w-72 h-72 bg-contain bg-no-repeat bg-center relative z-10 transition-all duration-500"></div>
        <h2 id="evo-txt-flash" class="mt-12 text-4xl font-black text-slate-900 z-10 text-center px-6">
            等等... <br> 小火龍的樣子有點奇怪！
        </h2>
    </div>

    <script>
        function startEvolution() {
            const ov = document.getElementById('evo-overlay');
            const img = document.getElementById('evo-img-flash');
            const txt = document.getElementById('evo-txt-flash');
            const ring = document.getElementById('blast-circle');

            // 1. 顯示過場
            ov.style.display = 'flex';
            img.style.backgroundImage = "url('https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/4.png')";
            img.classList.add('evo-anim');

            // 2. 模擬進化的緊張感 (3秒後進化)
            setTimeout(() => {
                // 炸開光芒
                ring.style.display = 'block';
                
                // 更換背景與文字
                ov.style.backgroundColor = 'rgba(0,0,0,0.95)';
                img.classList.remove('evo-anim');
                img.style.backgroundImage = "url('https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/5.png')"; // 火恐龍
                img.style.transform = "scale(1.3)";
                
                txt.innerHTML = "恭喜！<br><span class='text-yellow-400 text-6xl'>小火龍進化成火恐龍了！</span>";
                txt.className = "mt-12 font-black z-10 text-center px-6 transition-all duration-700";

                // 3. 結束過場回歸主畫面
                setTimeout(() => {
                    ov.style.opacity = '0';
                    setTimeout(() => {
                        location.reload(); // 測試完重置
                    }, 500);
                }, 4000);
            }, 3000);
        }
    </script>
</body>
</html>
